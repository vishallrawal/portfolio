---
import ServiceCard from "./ServiceCard.astro";
import { FaLaptopCode, FaBolt, FaRocket } from "react-icons/fa";
---

<section class="site-container mt-14 mx-auto max-w-6xl px-4">
	<h2
		class="text-4xl font-bold flex flex-col items-center gap-6 text-center whitespace-nowrap text-white md:flex-row md:items-center md:text-end"
	>
		<span class="hidden h-1.5 grow rounded-lg drop-shadow-[2px_2px_0_#0debd8] bg-[#7836cf] md:block"></span>
		<span class="drop-shadow-[2px_2px_0_#7836cf]">What I Do</span>
	</h2>

	<div class="mt-10 grid gap-6 md:grid-cols-3">
		<ServiceCard
			icon={FaLaptopCode}
			title="Responsive Web Development"
			description="Building modern, responsive, and mobile-friendly websites with clean design and optimized performance."
		/>

		<ServiceCard
			icon={FaBolt}
			title="Frontend Development"
			description="Creating interactive and user-friendly interfaces using modern web technologies and best UI practices."
		/>

		<ServiceCard
			icon={FaRocket}
			title="Backend Development"
			description="Developing efficient server-side functionality, APIs, and database integration for scalable web applications."
		/>
	</div>
</section>