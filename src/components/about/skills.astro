---
const technologies = [
  "react",
  "angular",
  "vue",
  "tailwindcss",
  "javaScript",
  "typeScript",
  "astro",
  "nodejs",
  "mysql",
  "supabase",
  "git",
  "bash",
];
---

<section class="mt-24 mx-auto max-w-6xl px-6">
  <!-- Section Title -->
  <div class="text-center space-y-3 mb-16">
    <span class="text-xs font-bold tracking-widest text-cyan-400 uppercase">Skills</span>
    <h2 class="text-3xl sm:text-5xl font-black text-white uppercase font-display leading-tight">
      Tech Stack
    </h2>
    <div class="h-1 w-20 bg-gradient-to-r from-purple-500 to-cyan-500 mx-auto rounded-full"></div>
  </div>

  <!-- Skills Grid -->
  <div class="grid gap-6 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
    {
      technologies.map((tech) => (
        <div
          class="group relative flex flex-col items-center justify-center p-6 rounded-2xl glass-card border-white/5 hover:border-purple-500/30 text-center transition-all duration-300"
        >
          <img
            src={`${import.meta.env.BASE_URL}svg/${tech}.svg`}
            alt={tech}
            class="h-12 w-auto object-contain transition-transform duration-300 group-hover:scale-110 filter grayscale opacity-60 group-hover:filter-none group-hover:opacity-100"
            width="48"
            height="48"
            loading="lazy"
          />

          <h3 class="mt-4 text-xs sm:text-sm font-bold tracking-wider text-gray-400 group-hover:text-white uppercase transition-colors">
            {tech === "javaScript" ? "JavaScript" : tech === "typeScript" ? "TypeScript" : tech}
          </h3>
        </div>
      ))
    }
  </div>
</section>