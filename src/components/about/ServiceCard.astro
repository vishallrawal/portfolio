---
interface Props {
  icon: any;
  title: string;
  description: string;
}

const { icon: Icon, title, description } = Astro.props;
---

<div
  class="group relative flex flex-col items-center justify-center overflow-hidden rounded-2xl p-8 glass-card border-white/5 hover:border-cyan-500/30 text-center"
>
  <!-- Icon container -->
  <div
    class="mb-5 text-4xl text-cyan-400 group-hover:scale-110 transition-transform duration-300 filter drop-shadow-[0_0_8px_rgba(6,182,212,0.4)]"
  >
    {Icon && <Icon />}
  </div>

  <!-- Title -->
  <h3 class="mb-3 text-xl font-bold text-white tracking-tight">{title}</h3>

  <!-- Description -->
  <p class="text-sm font-medium text-gray-400 leading-relaxed">{description}</p>
</div>
