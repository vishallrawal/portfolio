---
const githubUrl = "https://github.com/vishallrawal";
const imageUrl = `${import.meta.env.BASE_URL}github.png`;
---

<section class="mt-20 flex justify-center px-6">
  <div
    class="mx-auto w-full max-w-6xl overflow-hidden rounded-3xl bg-gradient-to-r from-purple-950/40 to-slate-900/60 border border-white/10 text-white shadow-2xl relative"
  >
    <!-- Background glowing light spot -->
    <div class="absolute right-0 top-0 w-64 h-64 bg-purple-500/10 blur-[80px] pointer-events-none"></div>

    <div class="flex flex-col md:flex-row-reverse items-center justify-between p-8 md:p-12 gap-8">
      
      <!-- Logo Image Column -->
      <div class="w-full max-w-[240px] md:max-w-[320px] flex-shrink-0 flex items-center justify-center">
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="block group">
          <img
            src={imageUrl}
            alt="GitHub logo"
            class="h-auto w-full object-contain group-hover:scale-105 transition-transform duration-300 filter drop-shadow-[0_0_15px_rgba(139,92,246,0.3)]"
          />
        </a>
      </div>

      <!-- Info Column -->
      <div class="flex-1 text-center md:text-left space-y-4">
        <span class="text-xs font-bold tracking-widest text-cyan-400 uppercase">Open Source</span>
        <h3 class="text-3xl sm:text-4xl font-extrabold text-white font-display leading-tight">
          Explore My Contributions On GitHub
        </h3>

        <p class="text-gray-400 text-sm sm:text-base font-medium leading-relaxed max-w-xl">
          Check out my public repositories, contribution graph, code samples, and collaborative commits to various open-source ecosystems.
        </p>

        <div class="pt-2">
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-6 py-3 bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white font-bold rounded-xl transition-all duration-300 glow-btn-purple text-sm uppercase tracking-wider"
          >
            Visit Profile
          </a>
        </div>
      </div>

    </div>
  </div>
</section>