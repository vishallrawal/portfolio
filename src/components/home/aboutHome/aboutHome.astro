---
import { HiArrowRight } from "react-icons/hi";
import MiFoto from "../../../assets/img/vishal.png";
---

<section class="relative flex items-center justify-center px-6 py-20 bg-transparent">
  <!-- Glowing subtle spots behind the card -->
  <div class="absolute inset-0 -z-10 flex items-center justify-center pointer-events-none">
    <div class="h-[300px] w-[500px] rounded-full bg-purple-600/5 blur-[120px]"></div>
  </div>

  <div class="mx-auto flex max-w-5xl flex-col items-center gap-12 md:flex-row">
    
    <!-- Profile Image Showcase -->
    <div class="relative w-full max-w-[280px] sm:max-w-[320px] md:w-1/3 flex-shrink-0 group">
      <!-- Glow board border backdrops -->
      <div class="absolute inset-0 bg-gradient-to-r from-purple-500 to-cyan-500 rounded-3xl blur-[12px] opacity-40 group-hover:opacity-60 transition-opacity duration-300"></div>
      
      <div class="relative bg-gray-900 border border-white/10 overflow-hidden rounded-3xl aspect-square shadow-2xl">
        <img
          src={MiFoto.src}
          alt="Vishal Rawal"
          class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      </div>
    </div>

    <!-- About Me Text Content -->
    <div class="w-full md:w-2/3 space-y-6">
      <div class="space-y-2">
        <span class="text-xs font-bold tracking-widest text-cyan-400 uppercase">Introduction</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white font-display">
          Crafting Scalable, Premium Digital Products
        </h2>
      </div>

      <p class="text-gray-400 text-sm sm:text-base font-medium leading-relaxed">
        I am a dedicated Web Developer specializing in building modern, fast, and gorgeous interfaces. Equipped with solid expertise in modern frameworks like React, Angular, Vue, and Backend integrations via Node.js, Socket.io, and relational/no-SQL databases.
      </p>
      
      <p class="text-gray-400 text-sm sm:text-base font-medium leading-relaxed">
        I bridge the gap between aesthetics and functionality, engineering design systems from scratch with Tailwind CSS and utilizing Astro's islands architecture for optimized zero-JS content performance.
      </p>

      <div class="pt-2">
        <a
          href={`${import.meta.env.BASE_URL}about`}
          class="group inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-purple-600/10 hover:bg-purple-600 text-purple-300 hover:text-white border border-purple-500/20 font-bold transition-all duration-300 text-sm glow-btn-purple"
        >
          Learn More About Me
          <HiArrowRight
            className="transition-transform duration-200 group-hover:translate-x-1"
            size={16}
          />
        </a>
      </div>
    </div>

  </div>
</section>