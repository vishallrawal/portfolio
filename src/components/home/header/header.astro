---
import SocialIcons from "../../commons/socialIcons/socialIcons.jsx";
import TypeEfect from "../header/typeEfect.jsx";
---

<header class="relative h-[90vh] bg-transparent overflow-hidden flex items-center justify-center">
  <!-- Glowing Abstract Spheres (Animated via CSS in global.css) -->
  <div class="absolute inset-0 z-0">
    <div class="absolute top-[20%] left-[20%] w-[350px] h-[350px] rounded-full bg-purple-600/10 blur-[100px] animate-gradientMove"></div>
    <div class="absolute bottom-[20%] right-[20%] w-[350px] h-[350px] rounded-full bg-cyan-600/10 blur-[100px] animate-gradientMove2"></div>
  </div>

  <!-- Tech Grid Coordinates Backdrop Overlay -->
  <div class="absolute inset-0 bg-[radial-gradient(#1e293b_1px,transparent_1px)] [background-size:24px_24px] opacity-10 pointer-events-none"></div>

  <div class="relative z-10 flex flex-col items-center justify-center text-center px-6 max-w-4xl mx-auto mt-10">
    
    <!-- Welcome Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-300 text-xs font-bold tracking-wider uppercase mb-6">
      <span class="w-2 h-2 rounded-full bg-purple-500 animate-pulse"></span>
      Welcome to my creative universe
    </div>

    <!-- Main Title -->
    <h1 class="text-4xl sm:text-6xl md:text-8xl font-black tracking-tight text-white mb-4 uppercase font-display leading-[0.95]">
      Vishal <span class="text-gradient">Rawal</span>
    </h1>

    <!-- Subtitle Typewriter -->
    <TypeEfect client:load />

    <!-- Intro Text -->
    <p class="text-gray-400 max-w-md sm:max-w-xl font-medium mt-6 text-sm sm:text-base md:text-lg leading-relaxed">
      Designing & building dynamic, high-graphics digital ecosystems. Focused on premium frontend crafts, WebSockets, and clean coding architectures.
    </p>

    <!-- Social Connections -->
    <div class="mt-4">
      <SocialIcons client:load />
    </div>

    <!-- Action Buttons -->
    <div class="mt-6 flex flex-col sm:flex-row gap-4 items-center justify-center">
      <a
        href={`${import.meta.env.BASE_URL}proyectos`}
        class="px-8 py-3.5 bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white font-bold rounded-2xl transition-all duration-300 glow-btn-purple text-sm sm:text-base uppercase tracking-wider"
      >
        Explore Projects
      </a>
      <a
        target="_blank"
        href={`${import.meta.env.BASE_URL}vishal-resume.pdf`}
        class="px-8 py-3.5 bg-gray-900/80 border border-white/10 hover:bg-gray-900 text-white font-bold rounded-2xl transition-all duration-300 glow-btn-cyan text-sm sm:text-base uppercase tracking-wider"
      >
        Download Resume
      </a>
    </div>

  </div>
</header>
