---
const technologies = [
  "react",
  "angular",
  "vue",
  "tailwindcss",
  "javaScript",
  "typeScript",
  "astro",
  "nodejs",
  "HTML5",
  "CSS3",
  "supabase",
  "mysql",
  "git",
];
---

<div class="relative overflow-x-hidden py-10 bg-transparent border-y border-white/5">
  <!-- Left overlay fade -->
  <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-[#030712] to-transparent z-10 pointer-events-none"></div>
  
  <!-- Right overlay fade -->
  <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-[#030712] to-transparent z-10 pointer-events-none"></div>

  <div class="animate-scroll hover:animate-paused flex w-max gap-16 md:gap-24">
    {
      technologies.concat(technologies, technologies).map((tech) => (
        <div class="group flex items-center gap-3 transition-all duration-300">
          <img
            src={`${import.meta.env.BASE_URL}svg/${tech}.svg`}
            alt={tech}
            class="h-8 w-auto object-contain transition-all duration-300 filter grayscale opacity-60 group-hover:filter-none group-hover:opacity-100 group-hover:scale-110"
            width="32"
            height="32"
            loading="lazy"
          />
          <span class="text-sm sm:text-base font-bold tracking-wider text-gray-500 group-hover:text-white transition-colors uppercase">
            {tech === "javaScript" ? "JavaScript" : tech === "typeScript" ? "TypeScript" : tech}
          </span>
        </div>
      ))
    }
  </div>
</div>

<style is:global>
  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .animate-scroll {
    animation: scroll 40s linear infinite;
  }

  .animate-scroll:hover {
    animation-play-state: paused;
  }

  @media (min-width: 768px) {
    .animate-scroll {
      animation-duration: 50s;
    }
  }
</style>