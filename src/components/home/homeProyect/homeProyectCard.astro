---
export interface Props {
  titulo: string;
  imagen: string;
  tecnologias: string[];
  demo: string;
  codigo: string;
}

const { titulo, imagen, tecnologias, demo, codigo } = Astro.props;
---

<div class="group glass-card rounded-2xl overflow-hidden flex flex-col h-full border-white/5 hover:border-purple-500/30">
  <!-- Card image container with scaling mask -->
  <div class="relative h-48 overflow-hidden bg-gray-950/40">
    <!-- Overlay accent gradient mask -->
    <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-transparent to-transparent opacity-60 z-10"></div>
    <img
      src={imagen}
      alt={`Project: ${titulo}`}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
  </div>

  <div class="p-5 flex flex-col grow space-y-4">
    <div class="space-y-1">
      <h3 class="text-lg font-bold text-white group-hover:text-purple-400 transition-colors">
        {titulo}
      </h3>
    </div>

    <!-- Technologies list -->
    <div class="flex flex-wrap gap-1.5">
      {
        tecnologias.map((tech) => (
          <span class="rounded-md bg-purple-500/10 text-purple-300 border border-purple-500/10 px-2 py-0.5 text-xs font-semibold">
            {tech}
          </span>
        ))
      }
    </div>

    <!-- Action links -->
    <div class="mt-auto pt-4 flex items-center justify-between gap-4 border-t border-white/5">
      <a
        href={demo}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full text-center border border-white/10 hover:border-cyan-500/50 hover:bg-cyan-500/10 text-gray-300 hover:text-cyan-400 py-2 rounded-xl text-xs font-bold transition-all"
      >
        Live Demo
      </a>

      <a
        href={codigo}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full text-center border border-white/10 hover:border-purple-500/50 hover:bg-purple-500/10 text-gray-300 hover:text-purple-400 py-2 rounded-xl text-xs font-bold transition-all"
      >
        Source Code
      </a>
    </div>
  </div>
</div>