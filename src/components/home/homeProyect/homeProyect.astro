---
import HomeProjectCard from "./homeProyectCard.astro";
import { proyectos } from "../../../data/projetsAboutData.js";
---

<section class="py-20 relative bg-transparent">
  <!-- Glowing subtle spots behind projects grid -->
  <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 flex items-center justify-between pointer-events-none -z-10">
    <div class="h-[400px] w-[400px] rounded-full bg-cyan-600/5 blur-[120px] left-[-10%] relative"></div>
    <div class="h-[400px] w-[400px] rounded-full bg-purple-600/5 blur-[120px] right-[-10%] relative"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6">
    <!-- Header title -->
    <div class="text-center space-y-3 mb-16">
      <span class="text-xs font-bold tracking-widest text-cyan-400 uppercase">Portfolio</span>
      <h2 class="text-3xl sm:text-5xl font-black text-white uppercase font-display leading-tight">
        Featured Projects
      </h2>
      <div class="h-1 w-20 bg-gradient-to-r from-purple-500 to-cyan-500 mx-auto rounded-full"></div>
    </div>

    <!-- Cards grid -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {proyectos.map((p) => <HomeProjectCard {...p} />)}
    </div>

    <!-- Action button -->
    <div class="mt-16 flex justify-center">
      <a
        href={`${import.meta.env.BASE_URL}proyectos`}
        class="px-8 py-3.5 bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white font-bold rounded-2xl transition-all duration-300 glow-btn-purple text-sm uppercase tracking-wider"
      >
        View All Projects
      </a>
    </div>
  </div>
</section>
