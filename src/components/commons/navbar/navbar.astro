---
import { FiMenu, FiX } from "react-icons/fi";
import { FaLinkedinIn, FaGithub } from "react-icons/fa6";

const navLinks = [
  { name: "Home", href: import.meta.env.BASE_URL },
  { name: "Projects", href: `${import.meta.env.BASE_URL}proyectos` },
  { name: "About", href: `${import.meta.env.BASE_URL}about` },
  { name: "Contact", href: `${import.meta.env.BASE_URL}contact` },
];
---

<nav class="relative">
  <input id="menu-toggle" type="checkbox" class="peer hidden md:hidden" />

  <nav
    class="fixed top-0 left-0 w-full z-50 bg-gray-950/20 backdrop-blur-md border-b border-white/10"
  >
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

      <a href={import.meta.env.BASE_URL} class="flex items-center">
        <h3
          class="text-[#69c7c7] text-3xl font-bold drop-shadow-[1.5px_1.5px_0_#7836cf]"
        >
          VR
        </h3>
      </a>

      <ul id="navbar-links" class="hidden md:flex items-center space-x-8">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="nav-link font-bold transition-colors duration-300 text-white hover:text-[#7d2dac]"
              >
                {link.name}
              </a>
            </li>
          ))
        }
      </ul>

    </div>
  </nav>

  <div
    class="fixed top-0 right-0 h-full w-64 bg-gray-900 shadow-lg transform translate-x-full transition-transform duration-300 peer-checked:translate-x-0 z-50 md:hidden"
  >
    <ul id="navbar-links-mobile" class="flex flex-col space-y-6 mt-6 ml-6">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link-mobile text-lg font-bold text-white hover:text-[#69c7c7]"
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>