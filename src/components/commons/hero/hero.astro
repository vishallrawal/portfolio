---
export interface Props {
  titulo: string;
}

const { titulo } = Astro.props;
---

<section class="relative py-20 overflow-hidden bg-transparent">
  <!-- Glowing subtle lines -->
  <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-purple-500/20 to-transparent"></div>
  
  <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
    <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white mb-2 uppercase font-display">
      <span class="text-gradient-cyan">{titulo}</span>
    </h1>
    <div class="h-1 w-20 bg-gradient-to-r from-purple-500 to-cyan-500 mx-auto rounded-full mt-4"></div>
  </div>
</section>
