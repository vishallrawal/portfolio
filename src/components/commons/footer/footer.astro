---
import SocialIcons from "../socialIcons/socialIcons.jsx";

const links = [
  { name: "Home", href: import.meta.env.BASE_URL },
  { name: "Projects", href: `${import.meta.env.BASE_URL}proyectos` },
  { name: "About Me", href: `${import.meta.env.BASE_URL}about` },
  { name: "Blog Section", href: `${import.meta.env.BASE_URL}blog` },
  { name: "Contact Me", href: `${import.meta.env.BASE_URL}contact` },
];

const projects = [
  { name: "FlixCart Shopping", href: "https://github.com/vishallrawal/FlixCart-Website" },
  { name: "Movie Ticket System", href: "https://github.com/vishallrawal/movie-website" },
  { name: "Interactive Chatbot", href: "https://github.com/vishallrawal/chatbot" },
  { name: "C CLI Guessing Game", href: "https://github.com/vishallrawal/number-guessing-game" },
];
---

<footer class="relative mt-24 border-t border-white/5 bg-[#070b14] overflow-hidden">
  <!-- Glowing subtle accents inside footer -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[60vw] h-[300px] rounded-full bg-purple-900/10 blur-[100px] pointer-events-none -z-10"></div>
  
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <!-- Brand & Bio Column -->
      <div class="space-y-4">
        <a href={import.meta.env.BASE_URL} class="inline-block group">
          <span class="text-3xl font-extrabold tracking-wider bg-clip-text text-transparent bg-gradient-to-r from-purple-400 to-cyan-400">
            VR
          </span>
        </a>
        <p class="text-gray-400 text-sm font-medium leading-relaxed max-w-xs">
          Creative Web Developer crafting advanced, high-performance web applications using React, Angular, Vue, and Node.js.
        </p>
        <div class="pt-2 flex justify-start">
          <SocialIcons client:visible />
        </div>
      </div>

      <!-- Quick Navigation Column -->
      <div class="space-y-4">
        <h4 class="text-white text-sm font-semibold tracking-wider uppercase">Navigation</h4>
        <ul class="space-y-2.5">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-400 text-sm font-medium hover:text-white transition-colors duration-200"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Top Repos Column -->
      <div class="space-y-4">
        <h4 class="text-white text-sm font-semibold tracking-wider uppercase">Featured Work</h4>
        <ul class="space-y-2.5">
          {
            projects.map((project) => (
              <li>
                <a
                  href={project.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-gray-400 text-sm font-medium hover:text-white transition-colors duration-200"
                >
                  {project.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Mock Newsletter Column -->
      <div class="space-y-4">
        <h4 class="text-white text-sm font-semibold tracking-wider uppercase">Stay Updated</h4>
        <p class="text-gray-400 text-sm font-medium leading-relaxed">
          Subscribe to get notified when I publish articles on frontend trends.
        </p>
        <form class="flex flex-col sm:flex-row gap-2 pt-2" id="footer-newsletter-form">
          <input
            type="email"
            placeholder="Enter your email"
            required
            class="flex-1 px-4 py-2.5 rounded-xl bg-gray-900 border border-white/10 text-white text-sm focus:border-purple-500 focus:outline-none transition-colors"
          />
          <button
            type="submit"
            class="px-4 py-2.5 bg-purple-600 hover:bg-purple-500 text-white text-sm font-bold rounded-xl transition-all glow-btn-purple shrink-0"
          >
            Subscribe
          </button>
        </form>
        <div id="footer-newsletter-success" class="hidden text-xs text-green-400 font-semibold mt-2">
          🎉 Awesome! You've been subscribed to the newsletter.
        </div>
      </div>

    </div>

    <!-- Copyright Area -->
    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-xs font-semibold text-center md:text-left">
        &copy; {new Date().getFullYear()} Vishal Rawal. All Rights Reserved. 
        Designed by <a href="https://www.linkedin.com/in/vishaalrawal448" target="_blank" rel="noopener noreferrer" class="text-purple-400 hover:text-purple-300 underline transition-colors">Vishal Rawal</a>.
      </p>
      <div class="flex space-x-6 text-gray-500 text-xs font-semibold">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  // Mock newsletter form submission handler
  const newsletterForm = document.getElementById('footer-newsletter-form');
  const newsletterSuccess = document.getElementById('footer-newsletter-success');

  if (newsletterForm && newsletterSuccess) {
    newsletterForm.addEventListener('submit', (e) => {
      e.preventDefault();
      newsletterForm.classList.add('hidden');
      newsletterSuccess.classList.remove('hidden');
    });
  }
</script>