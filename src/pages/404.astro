---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Page Not Found" description="The requested page could not be found.">
  <section
    class="min-h-[80vh] flex flex-col items-center justify-center px-6 text-center relative"
  >
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none -z-10">
      <div class="h-[300px] w-[300px] rounded-full bg-purple-600/10 blur-[100px]"></div>
    </div>

    <h1
      class="text-8xl sm:text-9xl font-black text-white font-display mb-4 tracking-tight"
    >
      <span class="text-gradient">404</span>
    </h1>

    <h2 class="text-2xl sm:text-3xl text-white font-bold mb-4 font-display uppercase tracking-wide">
      Page Not Found
    </h2>

    <p class="text-gray-400 max-w-md mx-auto mb-10 font-medium leading-relaxed">
      The link you followed may be broken, or the page has been removed. You can return back to the main homepage.
    </p>

    <a
      href={import.meta.env.BASE_URL}
      class="px-8 py-3.5 bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white font-bold rounded-2xl transition-all duration-300 glow-btn-purple text-sm uppercase tracking-wider"
    >
      Return Home
    </a>
  </section>
</Layout>
