---
import Layout from "../layouts/Layout.astro";
import MiFoto from "../assets/img/vishal.png";
import CopyMail from "../components/links/copyMail.jsx";
import ContactForm from "../components/links/ContactForm.jsx";
import { FaLinkedinIn, FaGithub, FaInstagram } from "react-icons/fa6";

const socialLinks = [
  {
    href: "https://www.linkedin.com/in/vishaalrawal448",
    label: "LinkedIn",
    icon: FaLinkedinIn,
    color: "hover:text-[#0077b5]"
  },
  {
    href: "https://github.com/vishallrawal",
    label: "GitHub",
    icon: FaGithub,
    color: "hover:text-white"
  },
  {
    href: "https://www.instagram.com/vishxall._?igsh=MTFuc2h0aW10NXo4ZQ%3D%3D",
    label: "Instagram",
    icon: FaInstagram,
    color: "hover:text-[#e1306c]"
  },
];
---

<Layout 
  title="Contact Me | Vishal Rawal" 
  description="Get in touch with me! Submit your details, copy my email address, or follow my LinkedIn, Github, and Instagram."
>
  <section class="max-w-6xl mx-auto px-6 py-20 relative bg-transparent min-h-[85vh] flex flex-col justify-center">
    
    <!-- Top glowing background circles -->
    <div class="absolute inset-0 flex items-center justify-between pointer-events-none -z-10">
      <div class="h-[400px] w-[400px] rounded-full bg-purple-600/5 blur-[120px] left-[10%] relative"></div>
      <div class="h-[400px] w-[400px] rounded-full bg-cyan-600/5 blur-[120px] right-[10%] relative"></div>
    </div>

    <div class="flex flex-col lg:flex-row gap-12 items-stretch justify-center">
      
      <!-- Left Column: Biography Summary & Direct Actions -->
      <div class="w-full lg:w-1/2 flex flex-col justify-between space-y-8">
        <div class="space-y-4 text-center lg:text-left">
          <span class="text-xs font-bold tracking-widest text-cyan-400 uppercase">Connect</span>
          <h2 class="text-3xl sm:text-5xl font-black text-white font-display uppercase leading-none">
            Get In <span class="text-gradient">Touch</span>
          </h2>
          <p class="text-gray-400 text-sm sm:text-base font-medium leading-relaxed max-w-md mx-auto lg:mx-0">
            Have a project in mind, an opportunity to discuss, or just want to say hi? Feel free to drop a message, copy my email, or reach out on socials!
          </p>
        </div>

        <!-- Open for opportunities circular badge -->
        <div class="flex items-center justify-center lg:justify-start">
          <div class="relative flex items-center justify-center">
            <img
              src={MiFoto.src}
              alt="Vishal Rawal"
              class="h-28 w-28 rounded-full border border-white/10 shadow-2xl object-cover"
            />
            <svg
              viewBox="0 0 200 200"
              class="animate-spin-slow absolute h-40 w-40"
            >
              <path
                id="circlePathText"
                d="M100,100 m-77,0 a77,77 0 1,1 154,0 a77,77 0 1,1 -154,0"
                fill="none"
              ></path>
              <text fill="#06b6d4" font-size="14" font-weight="bold" letter-spacing="1">
                <textPath href="#circlePathText" startOffset="0%">
                  ✦ Open for Opportunities ✦ Let's Connect!
                </textPath>
              </text>
            </svg>
          </div>
        </div>

        <!-- Email copy card -->
        <div class="flex justify-center lg:justify-start">
          <CopyMail client:load />
        </div>

        <!-- Social circles row -->
        <div class="flex items-center justify-center lg:justify-start gap-4">
          {
            socialLinks.map((social) => {
              const Icon = social.icon;
              return (
                <a
                  href={social.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={social.label}
                  class={`p-4 rounded-2xl glass-card border-white/5 text-gray-400 ${social.color} transition-all duration-300 hover:scale-105 hover:border-purple-500/20`}
                >
                  <Icon size={22} />
                </a>
              );
            })
          }
        </div>
      </div>

      <!-- Right Column: Interactive Contact Form -->
      <div class="w-full lg:w-1/2 flex items-center justify-center">
        <ContactForm client:load />
      </div>

    </div>
  </section>
</Layout>

<style>
  .animate-spin-slow {
    animation: spin 30s linear infinite;
  }

  @keyframes spin {
    100% {
      transform: rotate(360deg);
    }
  }
</style>