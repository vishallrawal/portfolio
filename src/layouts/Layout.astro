---
import "../styles/global.css";
import Navbar from "../components/commons/navbar/navbar.astro";
import Footer from "../components/commons/footer/footer.astro";

export interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Vishal Rawal | Portfolio & Blog", 
  description = "Welcome to my portfolio! I am a fullstack web developer specializing in Angular, Vue, React, Node.js, and modern styling frameworks." 
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`}/>
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="relative min-h-screen bg-[#030712] text-gray-100 overflow-x-hidden selection:bg-purple-500/30 selection:text-purple-200">
    <!-- Grid Overlay Background -->
    <div class="fixed inset-0 grid-overlay -z-40 pointer-events-none opacity-[0.25]"></div>
    
    <!-- Glowing Accent Circles -->
    <div class="fixed top-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-purple-700/10 blur-[120px] -z-50 pointer-events-none animate-pulse-slow"></div>
    <div class="fixed bottom-[-10%] right-[-10%] w-[50vw] h-[50vw] rounded-full bg-cyan-700/10 blur-[120px] -z-50 pointer-events-none animate-pulse-slow" style="animation-delay: 2s;"></div>
    
    <!-- Custom Mouse Glow Element (will be activated via client-side script in Home/Pages if wanted, or global) -->
    <div id="mouse-glow" class="fixed w-[400px] h-[400px] rounded-full bg-purple-500/5 blur-[80px] -z-50 pointer-events-none -translate-x-1/2 -translate-y-1/2 opacity-0 transition-opacity duration-500"></div>

    <Navbar />
    <main class="min-h-[80vh]">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      // Subtle dynamic mouse-glow following the cursor
      document.addEventListener('mousemove', (e) => {
        const glow = document.getElementById('mouse-glow');
        if (glow) {
          glow.style.left = e.clientX + 'px';
          glow.style.top = e.clientY + 'px';
          glow.style.opacity = '1';
        }
      });
      document.addEventListener('mouseleave', () => {
        const glow = document.getElementById('mouse-glow');
        if (glow) glow.style.opacity = '0';
      });
    </script>
  </body>
</html>
